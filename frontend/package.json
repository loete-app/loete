{
  "name": "frontend",
  "version": "0.0.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
