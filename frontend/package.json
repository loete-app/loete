    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^9.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "^21.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
